# GEMINI_API_KEY: Required for Gemini AI API calls (Optional in this project as no AI models are active, stored for compatibility).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Firebase Client Configuration (Optional but recommended for dynamic builds without hardcoding in JSON)
# If using build-time injection, prefix with VITE_ to expose them to the React frontend
VITE_FIREBASE_API_KEY="AIzaSyC..."
VITE_FIREBASE_AUTH_DOMAIN="mahira-d911b.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="mahira-d911b"
VITE_FIREBASE_STORAGE_BUCKET="mahira-d911b.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="652251198874"
VITE_FIREBASE_APP_ID="1:652251198874:web:c625538a..."
VITE_FIREBASE_MEASUREMENT_ID=""

# Firebase Deployment & CI/CD Pipeline
# These are used as Secrets in GitHub Actions, not bundled inside the built client bundle
FIREBASE_SERVICE_ACCOUNT_MAHIRA_D911B="your-service-account-json-string"
FIREBASE_PROJECT_ID="mahira-d911b"
